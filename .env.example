# 环境变量配置示例
# 将此文件复制为 .env 并填入你的 API 密钥

# OpenAI API Key (用于 GPT 模型和 OpenAI 兼容接口)
OPENAI_API_KEY=your_openai_api_key_here

# DashScope / 阿里云通义千问 API Key
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# Gemini API Key (可选，用于 Google Gemini 模型)
GEMINI_API_KEY=your_gemini_api_key_here

# MinerU PDF 解析服务 API Key
MINERU_API_KEY=your_mineru_api_key_here

# Jina Reranker API Key (可选，用于 Jina 重排模型)
# 获取地址: https://jina.ai/reranker/
JINA_API_KEY=your_jina_api_key_here
